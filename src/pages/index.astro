---
// Variables inyectadas en build-time por Astro (disponibles en el servidor)
const SUPABASE_URL = import.meta.env.VITE_SUPABASE_URL ?? ''
const SUPABASE_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY ?? ''
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Practica el examen teórico de la Licencia Clase B en Chile. Gratis, sin registro, sin límites." />
  <title>MiLicencia — Teórico Clase B gratis</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    /* ── Reset ─────────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      background: #fff; color: #111;
      -webkit-font-smoothing: antialiased;
      min-height: 100dvh;
    }
    button { font-family: inherit; cursor: pointer; }
    img { max-width: 100%; display: block; }

    /* ── Pantallas ─────────────────────────────────────────────── */
    .screen { display: none; min-height: 100dvh; flex-direction: column; }
    .screen.active { display: flex; }
    .screen-center { align-items: center; justify-content: center; }

    /* ── Nav ───────────────────────────────────────────────────── */
    .nav {
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 1.5rem; border-bottom: 1px solid #f0f0f0;
      position: sticky; top: 0; background: #fff; z-index: 20;
    }
    .nav-logo { display: flex; align-items: center; gap: 8px; font-size: 15px; font-weight: 600; }
    .dot { width: 9px; height: 9px; border-radius: 50%; background: #1D9E75; flex-shrink: 0; }
    .nav-right { display: flex; align-items: center; gap: 10px; }
    .user-email { font-size: 13px; color: #888; }

    /* ── Botones ───────────────────────────────────────────────── */
    .btn-primary {
      display: flex; align-items: center; justify-content: center;
      width: 100%; padding: .875rem 1.75rem;
      background: #111; color: #fff; border: none;
      border-radius: 10px; font-size: 15px; font-weight: 500;
      transition: background .15s;
    }
    .btn-primary:hover:not(:disabled) { background: #333; }
    .btn-primary:disabled { background: #999; cursor: default; }

    .btn-outline {
      display: flex; align-items: center; justify-content: center;
      width: 100%; padding: .875rem;
      background: transparent; color: #555;
      border: 1.5px solid #ddd; border-radius: 10px;
      font-size: 15px; transition: background .15s;
    }
    .btn-outline:hover { background: #f5f5f5; }

    .btn-ghost {
      background: none; border: 1px solid #e0e0e0;
      padding: .4rem .9rem; border-radius: 8px;
      font-size: 13px; color: #555; transition: background .15s;
    }
    .btn-ghost:hover { background: #f5f5f5; }

    .btn-link { background: none; border: none; color: #1D9E75; font-size: 14px; text-decoration: underline; }
    .btn-link:hover { color: #0F6E56; }

    /* ── HOME ──────────────────────────────────────────────────── */
    .home-body { max-width: 680px; margin: 0 auto; padding: 0 1.5rem 4rem; width: 100%; }

    .hero { padding: 3rem 0 2.5rem; text-align: center; }
    .hero-tag {
      display: inline-block; font-size: 12px; font-weight: 500;
      color: #1D9E75; background: #E1F5EE;
      border-radius: 20px; padding: 4px 12px;
      margin-bottom: 1.25rem; letter-spacing: .02em;
    }
    .hero h1 {
      font-size: clamp(26px, 5vw, 40px); font-weight: 700;
      line-height: 1.2; margin-bottom: 1rem;
    }
    .hero-sub {
      font-size: 16px; color: #555; line-height: 1.65;
      max-width: 460px; margin: 0 auto 1.75rem;
    }
    .hero-hint { font-size: 13px; color: #888; margin-top: .875rem; }
    .error-msg { color: #D85A30; font-size: 14px; margin-bottom: .75rem; background: #FAECE7; padding: .5rem .75rem; border-radius: 6px; }
    .hidden { display: none !important; }

    .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 2.5rem; }
    .stat { background: #F8F8F8; border-radius: 12px; padding: 1rem; text-align: center; }
    .stat-n { display: block; font-size: 28px; font-weight: 700; }
    .stat-l { display: block; font-size: 12px; color: #888; margin-top: 4px; }

    .features { display: flex; flex-direction: column; gap: 12px; }
    .feature { display: flex; gap: 14px; padding: 1rem 1.25rem; border: 1px solid #f0f0f0; border-radius: 10px; }
    .feature-check { color: #1D9E75; font-weight: 700; font-size: 16px; flex-shrink: 0; margin-top: 2px; }
    .feature strong { display: block; font-size: 14px; margin-bottom: 3px; }
    .feature p { font-size: 13px; color: #777; line-height: 1.5; margin: 0; }

    /* ── AUTH ──────────────────────────────────────────────────── */
    .auth-card {
      background: #fff; border-radius: 16px; padding: 2rem;
      width: 100%; max-width: 400px;
      box-shadow: 0 4px 24px rgba(0,0,0,.08);
      margin: 1.5rem;
    }
    .btn-back { background: none; border: none; font-size: 13px; color: #888; margin-bottom: 1.25rem; display: block; }
    .btn-back:hover { color: #333; }
    .auth-logo { margin-bottom: 1.5rem; }

    .tabs { display: flex; border-bottom: 1px solid #eee; margin-bottom: 1.5rem; }
    .tab {
      flex: 1; padding: .75rem; background: none; border: none;
      font-size: 14px; color: #888;
      border-bottom: 2px solid transparent; margin-bottom: -1px;
    }
    .tab.active { color: #1D9E75; border-bottom-color: #1D9E75; font-weight: 500; }

    .form { display: flex; flex-direction: column; gap: 1rem; }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-size: 13px; font-weight: 500; color: #444; }
    .field input {
      padding: .75rem 1rem; border: 1px solid #ddd;
      border-radius: 8px; font-size: 14px; outline: none;
      font-family: inherit; transition: border-color .15s;
    }
    .field input:focus { border-color: #1D9E75; }
    .auth-error { color: #D85A30; font-size: 13px; background: #FAECE7; padding: .5rem .75rem; border-radius: 6px; }
    .auth-success { color: #085041; font-size: 13px; background: #E1F5EE; padding: .5rem .75rem; border-radius: 6px; }
    .auth-skip { text-align: center; margin-top: 1rem; font-size: 13px; color: #888; }

    /* ── LOADING ───────────────────────────────────────────────── */
    .loading-box { text-align: center; color: #888; font-size: 15px; }
    .spinner {
      width: 36px; height: 36px; margin: 0 auto 1rem;
      border: 3px solid #eee; border-top-color: #1D9E75;
      border-radius: 50%; animation: spin .7s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── QUIZ ──────────────────────────────────────────────────── */
    .quiz-topbar {
      display: flex; align-items: center; justify-content: space-between;
      padding: .875rem 1.25rem; border-bottom: 1px solid #f0f0f0;
      position: sticky; top: 0; background: #fff; z-index: 10;
    }
    .quiz-progress { font-size: 14px; font-weight: 500; color: #333; }
    .quiz-progress span { font-weight: 400; color: #999; }
    .timer { font-size: 14px; font-weight: 500; color: #1D9E75; min-width: 72px; text-align: right; }
    .timer.warn { color: #D85A30; }

    .progress-bar { height: 3px; background: #f0f0f0; }
    .progress-fill { height: 3px; background: #1D9E75; transition: width .35s ease; }

    .quiz-body { max-width: 640px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; width: 100%; }

    .q-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: .875rem; min-height: 26px; }
    .badge-double {
      font-size: 12px; padding: 3px 10px; border-radius: 20px;
      background: #FFF8E1; color: #E65100; border: 1px solid #FFE082;
    }
    .badge-cat { font-size: 12px; padding: 3px 10px; border-radius: 20px; background: #F0F0F0; color: #555; }

    .q-text { font-size: 18px; font-weight: 500; line-height: 1.55; margin-bottom: 1.5rem; }

    .q-image { margin-bottom: 1.25rem; border-radius: 10px; overflow: hidden; border: 1px solid #eee; }
    .q-image img { width: 100%; max-height: 260px; object-fit: contain; background: #f8f8f8; }

    .options { display: flex; flex-direction: column; gap: 10px; }
    .option {
      display: flex; align-items: center; gap: 12px;
      padding: .875rem 1rem; border: 1.5px solid #e8e8e8;
      border-radius: 10px; background: #fff; text-align: left; width: 100%;
      transition: border-color .15s, background .15s; cursor: pointer;
    }
    .option:hover:not([disabled]) { border-color: #1D9E75; background: #F0FBF7; }
    .option[disabled] { cursor: default; }
    .option.correct { border-color: #1D9E75 !important; background: #E1F5EE !important; }
    .option.wrong   { border-color: #D85A30 !important; background: #FAECE7 !important; }
    .option.dim     { opacity: .5; }

    .opt-letter {
      width: 28px; height: 28px; flex-shrink: 0; border-radius: 50%;
      border: 1.5px solid #ddd; display: flex; align-items: center;
      justify-content: center; font-size: 12px; font-weight: 600; color: #666;
    }
    .option.correct .opt-letter { background: #1D9E75; border-color: #1D9E75; color: #fff; }
    .option.wrong   .opt-letter { background: #D85A30; border-color: #D85A30; color: #fff; }
    .opt-text { flex: 1; font-size: 14px; color: #333; line-height: 1.4; }
    .option.correct .opt-text { color: #085041; }
    .option.wrong   .opt-text { color: #4A1B0C; }
    .opt-icon { font-size: 16px; flex-shrink: 0; }

    .explanation {
      margin-top: 1rem; padding: 1rem 1.25rem;
      border-radius: 10px; font-size: 14px; line-height: 1.6;
    }
    .explanation.correct { background: #E1F5EE; border-left: 3px solid #1D9E75; color: #085041; }
    .explanation.wrong   { background: #FFF8F5; border-left: 3px solid #D85A30; color: #333; }
    .explanation strong { display: block; margin-bottom: 4px; font-size: 13px; }
    .explanation p { margin: 0; }

    .btn-next {
      width: 100%; margin-top: 1.25rem; padding: .875rem;
      background: #111; color: #fff; border: none;
      border-radius: 10px; font-size: 15px; font-weight: 500;
      transition: background .15s;
    }
    .btn-next:hover { background: #333; }

    /* ── RESULT ────────────────────────────────────────────────── */
    .result-body { max-width: 480px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; width: 100%; }

    .verdict { border-radius: 14px; padding: 1.5rem; text-align: center; margin-bottom: 1.25rem; }
    .verdict.pass { background: #E1F5EE; }
    .verdict.fail { background: #FFF1EC; }
    .verdict-icon {
      display: inline-flex; width: 48px; height: 48px; border-radius: 50%;
      align-items: center; justify-content: center;
      font-size: 22px; margin-bottom: .75rem;
    }
    .verdict.pass .verdict-icon { background: #1D9E75; color: #fff; }
    .verdict.fail .verdict-icon { background: #D85A30; color: #fff; }
    .verdict h1 { font-size: 22px; font-weight: 600; margin-bottom: 6px; }
    .verdict.pass h1 { color: #085041; }
    .verdict.fail h1 { color: #4A1B0C; }
    .verdict p { font-size: 14px; }
    .verdict.pass p { color: #0F6E56; }
    .verdict.fail p { color: #7A3A20; }

    .score-card {
      display: flex; align-items: center; justify-content: space-between;
      background: #F8F8F8; border-radius: 12px;
      padding: 1.25rem 1.5rem; margin-bottom: 1.25rem;
    }
    .score-main { display: flex; align-items: baseline; gap: 6px; }
    .score-n { font-size: 42px; font-weight: 700; line-height: 1; }
    .score-total { font-size: 16px; color: #888; }
    .score-pct { font-size: 22px; font-weight: 600; color: #1D9E75; }

    .result-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 1.5rem; }
    .rstat { background: #F8F8F8; border-radius: 10px; padding: .875rem 1rem; }
    .rstat-n { display: block; font-size: 20px; font-weight: 600; }
    .rstat-l { display: block; font-size: 12px; color: #888; margin-top: 4px; }
    .green { color: #1D9E75; }
    .red   { color: #D85A30; }

    .threshold-wrap { margin-bottom: 2rem; }
    .threshold-bar { height: 8px; background: #eee; border-radius: 4px; position: relative; }
    .threshold-fill { height: 100%; border-radius: 4px; transition: width .6s ease; }
    .threshold-fill.pass { background: #1D9E75; }
    .threshold-fill.fail { background: #D85A30; }
    .threshold-mark {
      position: absolute; top: -4px; width: 2px; height: 16px;
      background: #333; transform: translateX(-50%);
    }
    .threshold-label {
      position: absolute; top: 20px; left: 50%;
      transform: translateX(-50%);
      font-size: 11px; color: #555; white-space: nowrap;
    }
    .result-actions { display: flex; flex-direction: column; gap: 10px; }

    /* ── Responsive ─────────────────────────────────────────────── */
    @media (max-width: 600px) {
      .stats-row { grid-template-columns: repeat(2,1fr); }
      .q-text { font-size: 16px; }
      .hero-sub { font-size: 15px; }
    }
    @media (max-width: 380px) {
      .result-stats { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>

<body>

<!-- ══════════════════════════════════════════════════════════
     PANTALLA: HOME
══════════════════════════════════════════════════════════ -->
<div id="s-home" class="screen active">
  <nav class="nav">
    <div class="nav-logo"><span class="dot"></span>MiLicencia</div>
    <div class="nav-right">
      <span class="user-email hidden" id="nav-email"></span>
      <button class="btn-ghost hidden" id="btn-signout">Salir</button>
      <button class="btn-ghost" id="btn-goto-auth">Iniciar sesión</button>
    </div>
  </nav>

  <div class="home-body">
    <div class="hero">
      <span class="hero-tag">Licencia Clase B · Chile · Gratis</span>
      <h1>Practica el teórico<br>y aprueba a la primera</h1>
      <p class="hero-sub">
        Simulacros gratuitos basados en el banco oficial CONASET.
        Sin registro, sin límites, sin pagos.
      </p>
      <div id="home-error" class="error-msg hidden"></div>
      <button class="btn-primary" id="btn-start" style="max-width:320px;margin:0 auto;">
        Comenzar simulacro →
      </button>
      <p class="hero-hint" id="hint-register">
        <button class="btn-link" id="btn-hint-auth">Regístrate gratis</button>
        para guardar tu historial
      </p>
    </div>

    <div class="stats-row">
      <div class="stat"><span class="stat-n">35</span><span class="stat-l">preguntas</span></div>
      <div class="stat"><span class="stat-n">45</span><span class="stat-l">minutos</span></div>
      <div class="stat"><span class="stat-n">33</span><span class="stat-l">puntos mínimos</span></div>
      <div class="stat"><span class="stat-n">3</span><span class="stat-l">preguntas doble puntaje</span></div>
    </div>

    <div class="features">
      <div class="feature">
        <span class="feature-check">✓</span>
        <div><strong>100% gratis</strong><p>Sin versión premium, sin límite de intentos</p></div>
      </div>
      <div class="feature">
        <span class="feature-check">✓</span>
        <div><strong>Explicación en cada pregunta</strong><p>Aprende por qué cada respuesta es correcta</p></div>
      </div>
      <div class="feature">
        <span class="feature-check">✓</span>
        <div><strong>Preguntas aleatorias</strong><p>Cada simulacro es diferente, como el examen real</p></div>
      </div>
      <div class="feature">
        <span class="feature-check">✓</span>
        <div><strong>Sin registro obligatorio</strong><p>Entra y practica de inmediato</p></div>
      </div>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PANTALLA: AUTH
══════════════════════════════════════════════════════════ -->
<div id="s-auth" class="screen screen-center">
  <div class="auth-card">
    <button class="btn-back" id="btn-auth-back">← Volver</button>
    <div class="nav-logo auth-logo"><span class="dot"></span>MiLicencia</div>

    <div class="tabs">
      <button class="tab active" id="tab-login" data-tab="login">Iniciar sesión</button>
      <button class="tab" id="tab-register" data-tab="register">Registrarse</button>
    </div>

    <div class="form" id="auth-form">
      <div class="field">
        <label for="auth-email">Correo electrónico</label>
        <input id="auth-email" type="email" placeholder="tu@correo.cl" required />
      </div>
      <div class="field">
        <label for="auth-pass">Contraseña</label>
        <input id="auth-pass" type="password" placeholder="••••••••" required minlength="6" />
      </div>
      <div id="auth-feedback" class="hidden"></div>
      <button class="btn-primary" id="btn-auth-submit">Entrar</button>
    </div>

    <p class="auth-skip">
      <button class="btn-link" id="btn-skip-auth">Practicar sin registrarse</button>
    </p>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PANTALLA: LOADING
══════════════════════════════════════════════════════════ -->
<div id="s-loading" class="screen screen-center">
  <div class="loading-box">
    <div class="spinner"></div>
    <p>Cargando preguntas...</p>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PANTALLA: QUIZ
══════════════════════════════════════════════════════════ -->
<div id="s-quiz" class="screen">
  <div class="quiz-topbar">
    <button class="btn-ghost" id="btn-quiz-exit">← Salir</button>
    <span class="quiz-progress" id="quiz-progress">1 <span>de 35</span></span>
    <span class="timer" id="quiz-timer">⏱ 45:00</span>
  </div>
  <div class="progress-bar">
    <div class="progress-fill" id="progress-fill" style="width:3%"></div>
  </div>

  <div class="quiz-body">
    <div class="q-meta" id="q-meta"></div>
    <h2 class="q-text" id="q-text"></h2>
    <div class="q-image hidden" id="q-image"><img id="q-img-el" src="" alt="Imagen de la pregunta" /></div>
    <div class="options" id="options-container"></div>
    <div class="explanation hidden" id="explanation">
      <strong id="expl-title"></strong>
      <p id="expl-text"></p>
    </div>
    <button class="btn-next hidden" id="btn-next">Siguiente →</button>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     PANTALLA: RESULTADO
══════════════════════════════════════════════════════════ -->
<div id="s-result" class="screen">
  <nav class="nav">
    <div class="nav-logo"><span class="dot"></span>MiLicencia</div>
  </nav>
  <div class="result-body">
    <div class="verdict" id="verdict">
      <div class="verdict-icon" id="verdict-icon"></div>
      <h1 id="verdict-title"></h1>
      <p id="verdict-msg"></p>
    </div>

    <div class="score-card">
      <div class="score-main">
        <span class="score-n" id="res-score"></span>
        <span class="score-total" id="res-max"></span>
      </div>
      <span class="score-pct" id="res-pct"></span>
    </div>

    <div class="result-stats">
      <div class="rstat"><span class="rstat-n green" id="res-correct"></span><span class="rstat-l">Correctas</span></div>
      <div class="rstat"><span class="rstat-n red"   id="res-incorrect"></span><span class="rstat-l">Incorrectas</span></div>
      <div class="rstat"><span class="rstat-n" id="res-time"></span><span class="rstat-l">Tiempo</span></div>
    </div>

    <div class="threshold-wrap">
      <div class="threshold-bar">
        <div class="threshold-fill" id="threshold-fill"></div>
        <div class="threshold-mark" id="threshold-mark">
          <span class="threshold-label">33 pts mínimo</span>
        </div>
      </div>
    </div>

    <div class="result-actions">
      <button class="btn-primary" id="btn-retry">Nuevo simulacro</button>
      <button class="btn-outline" id="btn-home">Volver al inicio</button>
    </div>
  </div>
</div>


<!-- ══════════════════════════════════════════════════════════
     LÓGICA JS VANILLA
══════════════════════════════════════════════════════════ -->
<script type="module" define:vars={{ SUPABASE_URL, SUPABASE_KEY }}>
  import { createClient } from 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm'

  // ── Config (inyectadas via define:vars desde el frontmatter Astro) ──
  const supabase = createClient(SUPABASE_URL, SUPABASE_KEY)

  const TIME_LIMIT    = 45 * 60
  const MIN_SCORE     = 33
  const LETTERS       = ['A','B','C','D']

  // ── Estado ───────────────────────────────────────────────
  let questions = []
  let current   = 0
  let answers   = []
  let timeLeft  = TIME_LIMIT
  let timerId   = null
  let answered  = false
  let authMode  = 'login'
  let session   = null

  // ── Helpers DOM ──────────────────────────────────────────
  const $  = id => document.getElementById(id)
  const el = (tag, cls, html='') => {
    const e = document.createElement(tag)
    if (cls) e.className = cls
    if (html) e.innerHTML = html
    return e
  }

  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'))
    $(id).classList.add('active')
  }

  function fmtTime(s) {
    const m = Math.floor(s / 60)
    const sec = s % 60
    return `${m}:${sec.toString().padStart(2,'0')}`
  }

  // ── Auth ─────────────────────────────────────────────────
  async function checkSession() {
    const { data } = await supabase.auth.getSession()
    session = data.session
    updateNavAuth()
  }

  function updateNavAuth() {
    if (session) {
      $('nav-email').textContent = session.user.email
      $('nav-email').classList.remove('hidden')
      $('btn-signout').classList.remove('hidden')
      $('btn-goto-auth').classList.add('hidden')
      $('hint-register').classList.add('hidden')
    } else {
      $('nav-email').classList.add('hidden')
      $('btn-signout').classList.add('hidden')
      $('btn-goto-auth').classList.remove('hidden')
      $('hint-register').classList.remove('hidden')
    }
  }

  $('btn-signout').addEventListener('click', async () => {
    await supabase.auth.signOut()
    session = null
    updateNavAuth()
  })

  $('btn-goto-auth').addEventListener('click', () => showScreen('s-auth'))
  $('btn-hint-auth').addEventListener('click', () => showScreen('s-auth'))
  $('btn-auth-back').addEventListener('click', () => showScreen('s-home'))
  $('btn-skip-auth').addEventListener('click', () => showScreen('s-home'))

  // Tabs auth
  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => {
      authMode = tab.dataset.tab
      document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'))
      tab.classList.add('active')
      $('btn-auth-submit').textContent = authMode === 'login' ? 'Entrar' : 'Crear cuenta'
      $('auth-pass').placeholder = authMode === 'register' ? 'Mínimo 6 caracteres' : '••••••••'
      $('auth-feedback').className = 'hidden'
      $('auth-feedback').textContent = ''
    })
  })

  $('btn-auth-submit').addEventListener('click', async () => {
    const email = $('auth-email').value.trim()
    const pass  = $('auth-pass').value
    const fb    = $('auth-feedback')
    fb.className = 'hidden'
    $('btn-auth-submit').disabled = true
    $('btn-auth-submit').textContent = 'Procesando...'

    try {
      if (authMode === 'login') {
        const { error } = await supabase.auth.signInWithPassword({ email, password: pass })
        if (error) {
          fb.textContent = 'Correo o contraseña incorrectos'
          fb.className = 'auth-error'
        } else {
          const { data } = await supabase.auth.getSession()
          session = data.session
          updateNavAuth()
          showScreen('s-home')
        }
      } else {
        const { error } = await supabase.auth.signUp({ email, password: pass })
        if (error) {
          fb.textContent = 'Error: ' + error.message
          fb.className = 'auth-error'
        } else {
          fb.textContent = 'Revisa tu correo para confirmar tu cuenta.'
          fb.className = 'auth-success'
          $('auth-email').value = ''
          $('auth-pass').value  = ''
        }
      }
    } finally {
      $('btn-auth-submit').disabled = false
      $('btn-auth-submit').textContent = authMode === 'login' ? 'Entrar' : 'Crear cuenta'
    }
  })

  // ── Cargar preguntas ─────────────────────────────────────
  async function loadQuestions() {
    const { data, error } = await supabase
      .from('questions')
      .select(`
        id, text, explanation, image_url, is_double_score,
        categories ( name ),
        question_options ( id, option_text, is_correct )
      `)
    if (error || !data?.length) throw new Error('No se pudieron cargar las preguntas.')

    const shuffle  = arr => arr.sort(() => Math.random() - 0.5)
    const critical = data.filter(q => q.is_double_score)
    const rest     = data.filter(q => !q.is_double_score)

    return shuffle([
      ...shuffle(critical).slice(0, Math.min(critical.length, 8)),
      ...shuffle(rest),
    ])
    .slice(0, 35)
    .map(q => ({ ...q, question_options: [...q.question_options].sort(() => Math.random() - 0.5) }))
  }

  // ── Inicio del simulacro ─────────────────────────────────
  async function startQuiz() {
    showScreen('s-loading')
    $('home-error').classList.add('hidden')
    clearInterval(timerId)
    answers  = []
    current  = 0
    answered = false
    timeLeft = TIME_LIMIT

    try {
      questions = await loadQuestions()
    } catch(e) {
      $('home-error').textContent = e.message
      $('home-error').classList.remove('hidden')
      showScreen('s-home')
      return
    }

    renderQuestion()
    showScreen('s-quiz')
    startTimer()
  }

  $('btn-start').addEventListener('click', startQuiz)
  $('btn-quiz-exit').addEventListener('click', () => { clearInterval(timerId); showScreen('s-home') })

  // ── Timer ────────────────────────────────────────────────
  function startTimer() {
    const timerEl = $('quiz-timer')
    timerId = setInterval(() => {
      timeLeft--
      timerEl.textContent = '⏱ ' + fmtTime(timeLeft)
      timerEl.classList.toggle('warn', timeLeft < 300)
      if (timeLeft <= 0) { clearInterval(timerId); finishQuiz() }
    }, 1000)
  }

  // ── Render pregunta ──────────────────────────────────────
  function renderQuestion() {
    const q = questions[current]
    const total = questions.length

    // Progreso
    $('quiz-progress').innerHTML = `<strong>${current + 1}</strong> <span>de ${total}</span>`
    $('progress-fill').style.width = `${((current + 1) / total) * 100}%`
    $('quiz-timer').textContent = '⏱ ' + fmtTime(timeLeft)

    // Meta badges
    const meta = $('q-meta')
    meta.innerHTML = ''
    if (q.is_double_score) meta.appendChild(el('span','badge-double','⭐ Vale 2 puntos'))
    if (q.categories?.name) meta.appendChild(el('span','badge-cat', q.categories.name))

    // Texto
    $('q-text').textContent = q.text

    // Imagen
    const imgWrap = $('q-image')
    if (q.image_url) {
      $('q-img-el').src = q.image_url
      imgWrap.classList.remove('hidden')
    } else {
      imgWrap.classList.add('hidden')
    }

    // Opciones
    const container = $('options-container')
    container.innerHTML = ''
    q.question_options.forEach((opt, i) => {
      const btn = el('button', 'option')
      btn.innerHTML = `
        <span class="opt-letter">${LETTERS[i]}</span>
        <span class="opt-text">${opt.option_text}</span>
        <span class="opt-icon"></span>
      `
      btn.addEventListener('click', () => selectOption(opt, btn))
      container.appendChild(btn)
    })

    // Reset estado
    answered = false
    $('explanation').classList.add('hidden')
    $('btn-next').classList.add('hidden')
    $('btn-next').textContent = current + 1 === total ? 'Ver resultado' : 'Siguiente →'
  }

  // ── Seleccionar opción ───────────────────────────────────
  function selectOption(opt, btnClicked) {
    if (answered) return
    answered = true

    const q = questions[current]
    const isCorrect = opt.is_correct
    answers.push({ question: q, chosen: opt, isCorrect })

    // Colorear todas las opciones
    $('options-container').querySelectorAll('.option').forEach(btn => {
      btn.disabled = true
      const optText = btn.querySelector('.opt-text').textContent
      const thisOpt = q.question_options.find(o => o.option_text === optText)
      if (!thisOpt) return

      if (thisOpt.is_correct) {
        btn.classList.add('correct')
        btn.querySelector('.opt-icon').textContent = '✓'
      } else if (thisOpt.id === opt.id && !isCorrect) {
        btn.classList.add('wrong')
        btn.querySelector('.opt-icon').textContent = '✗'
      } else {
        btn.classList.add('dim')
      }
    })

    // Explicación
    const expl = $('explanation')
    expl.className = 'explanation ' + (isCorrect ? 'correct' : 'wrong')
    $('expl-title').textContent = isCorrect ? '¡Correcto!' : 'Respuesta incorrecta'
    $('expl-text').textContent  = q.explanation
    expl.classList.remove('hidden')

    $('btn-next').classList.remove('hidden')
  }

  $('btn-next').addEventListener('click', () => {
    if (current + 1 >= questions.length) {
      clearInterval(timerId)
      finishQuiz()
    } else {
      current++
      renderQuestion()
    }
  })

  // ── Resultado ────────────────────────────────────────────
  async function finishQuiz() {
    const timeUsed = TIME_LIMIT - timeLeft
    let score = 0
    let maxScore = 0
    questions.forEach(q => { maxScore += q.is_double_score ? 2 : 1 })
    answers.forEach(a => { if (a.isCorrect) score += a.question.is_double_score ? 2 : 1 })

    const passed  = score >= MIN_SCORE
    const correct = answers.filter(a => a.isCorrect).length
    const wrong   = answers.filter(a => !a.isCorrect).length
    const pct     = Math.round((score / maxScore) * 100)

    // Guardar en Supabase si hay sesión
    if (session) {
      await supabase.from('attempts').insert({ user_id: session.user.id, score, passed })
    }

    // Render resultado
    const verdict = $('verdict')
    verdict.className = 'verdict ' + (passed ? 'pass' : 'fail')
    $('verdict-icon').textContent = passed ? '✓' : '✗'
    $('verdict-title').textContent = passed ? 'Aprobado' : 'Reprobado'
    $('verdict-msg').textContent   = passed
      ? '¡Alcanzaste el puntaje mínimo! Sigue practicando.'
      : `Necesitas ${MIN_SCORE} puntos. ¡Inténtalo de nuevo!`

    $('res-score').textContent   = score
    $('res-max').textContent     = `/ ${maxScore} pts`
    $('res-pct').textContent     = `${pct}%`
    $('res-correct').textContent = correct
    $('res-incorrect').textContent = wrong
    $('res-time').textContent    = fmtTime(timeUsed)

    const fill = $('threshold-fill')
    fill.className = 'threshold-fill ' + (passed ? 'pass' : 'fail')
    fill.style.width = Math.min(100, pct) + '%'

    const markPct = (MIN_SCORE / maxScore) * 100
    $('threshold-mark').style.left = markPct + '%'

    showScreen('s-result')
  }

  $('btn-retry').addEventListener('click', startQuiz)
  $('btn-home').addEventListener('click', () => showScreen('s-home'))

  // ── Init ─────────────────────────────────────────────────
  checkSession()
</script>

</body>
</html>